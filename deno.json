{
  "nodeModulesDir": "manual",
  "tasks": {
    "check": "deno fmt --check . && deno lint . && deno check",
    "dev": "deno run -A --unstable-kv npm:vite",
    "build": "vite build",
    "start": "deno serve -A --unstable-kv _fresh/server.js",
    "update": "deno run -A -r jsr:@fresh/update ."
  },
  "lint": { "rules": { "tags": ["fresh", "recommended"] } },
  "exclude": ["**/_fresh/*"],
  "imports": {
    "@/": "./",
    "@std/fs": "jsr:@std/fs@^1.0.24",
    "@std/http": "jsr:@std/http@^1.1.1",
    "fresh": "jsr:@fresh/core@^2.3.3",
    "preact": "npm:preact@^10.29.1",
    "@preact/signals": "npm:@preact/signals@^2.9.0",
    "@fresh/plugin-vite": "jsr:@fresh/plugin-vite@^1.1.2",
    "vite": "npm:vite@^7.1.3",
    "@types/babel__core": "npm:@types/babel__core@^7.20.5",
    "tailwindcss": "npm:tailwindcss@^4.1.10",
    "@tailwindcss/vite": "npm:@tailwindcss/vite@^4.1.12",
    "stripe": "npm:stripe@12.6.0",
    "feed": "npm:feed@4.2.2",
    "ptera": "https://deno.land/x/ptera@v1.0.2/mod.ts",
    "$std/http/cookie": "jsr:@std/http@^1.0.0/cookie",
    "$std/http/http_status": "jsr:@std/http@^1.0.0/http_status",
    "@deno/kv-oauth": "jsr:@deno/kv-oauth@^0.11.0",
    "kv_oauth": "jsr:@deno/kv-oauth@^0.11.0",
    "jsr:@std/fs/walk": "jsr:@std/fs@^1.0.24/walk",
    "jsr:@std/http/status": "jsr:@std/http@^1."
  },
  "compilerOptions": {
    "lib": ["dom", "dom.asynciterable", "dom.iterable", "deno.ns"],
    "jsx": "precompile",
    "jsxImportSource": "preact",
    "jsxPrecompileSkipElements": [
      "a",
      "img",
      "source",
      "body",
      "html",
      "head",
      "title",
      "meta",
      "script",
      "link",
      "style",
      "base",
      "noscript",
      "template"
    ],
    "types": ["vite/client"]
  }
}
